.DS_Store
Thumbs.db
*.log
node_modules/
dist/

# Composer dev tooling. plugin-update-checker under vendor/ is vendored by hand
# and committed; everything else Composer installs (PHPCS, WPCS) is dev-only.
/vendor/*
!/vendor/plugin-update-checker/

# PHP_CodeSniffer
.phpcs.cache
phpcs-report.xml
# Local ruleset override (see phpcs.xml.dist)
/phpcs.xml
